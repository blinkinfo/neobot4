# ==============================================================================
# NeoBotv1 — Polymarket BTC 5-Min Trading Bot
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------------------------------------------------------------------------------
# Telegram Configuration
# ------------------------------------------------------------------------------

# Bot token from @BotFather (REQUIRED)
TELEGRAM_BOT_TOKEN=

# Comma-separated list of authorized Telegram chat IDs (REQUIRED)
# Get your chat ID from @userinfobot on Telegram
# Example: TELEGRAM_ALLOWED_CHAT_IDS=123456789
# Multiple users: TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
TELEGRAM_ALLOWED_CHAT_IDS=

# ------------------------------------------------------------------------------
# Polymarket Configuration
# ------------------------------------------------------------------------------

# Wallet private key for signing trades (REQUIRED for trading)
# Can include or omit the 0x prefix — both are handled
POLYMARKET_PRIVATE_KEY=

# Your proxy/funder wallet address (REQUIRED for trading)
# This is the Gnosis Safe or proxy address that holds your funds
POLYMARKET_FUNDER_ADDRESS=

# Wallet signature type (OPTIONAL, default: 0)
#   0 = EOA (MetaMask, direct private key) — MOST COMMON
#   1 = Magic / email wallet
#   2 = Browser proxy / Gnosis Safe
# If trading fails with "invalid signature", try changing this value
POLYMARKET_SIGNATURE_TYPE=0

# Default quick-trade amount in USDC (OPTIONAL, default: 5)
QUICK_TRADE_AMOUNT=5
